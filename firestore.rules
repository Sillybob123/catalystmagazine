rules_version = '2';
// Deploy with:  firebase deploy --only firestore:rules
//
// Roles supported:
//   - admin               (ultimate control)
//   - editor              (edit/comment/approve drafts)
//   - writer              (submit + edit own drafts)
//   - newsletter_builder  (compose + send newsletters, read subscribers)
//   - marketing           (read subscribers + analytics)
//   - social_media        (marketing reads + the Planner: upcoming stories,
//                          publish notifications, comment-chat with authors)
//   - reader              (default for newly registered users)

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- role helpers ----------
    function isSignedIn() { return request.auth != null; }

    // Anonymous auth is enabled solely so the public Winners' Lounge chat
    // can sign visitors in invisibly. EVERY editorial/staff path must reject
    // anonymous tokens — only real (email/password) accounts may hold roles.
    function isAnonymous() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }
    function isRealUser() { return isSignedIn() && !isAnonymous(); }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function myRole() {
      return isRealUser() ? myUserDoc().data.role : null;
    }
    function hasRole(r) { return isRealUser() && myRole() == r; }
    function hasAnyRole(list) { return isRealUser() && myRole() in list; }

    // Per-user extra-access grants. Admins can grant a user access to specific
    // dashboard routes (by hash, e.g. '#/admin/submissions') beyond their base
    // role, via the "Extra access" modal in Users & roles. Stored as
    // users/{uid}.extraAccess: string[]. The UI gates the sidebar on this list;
    // these helpers let the security rules honor the same grants so a granted
    // page can actually read the collections it needs. Mirrors isRouteAllowed()
    // in js/dashboard/app.js and the server-side grant check in
    // functions/_utils/auth.js — keep all three in sync.
    function myExtraAccess() {
      return isRealUser() && ('extraAccess' in myUserDoc().data)
        ? myUserDoc().data.extraAccess : [];
    }
    function hasGrant(hash) { return isRealUser() && (hash in myExtraAccess()); }
    function hasAnyGrant(list) {
      return isRealUser() && myExtraAccess().hasAny(list);
    }

    function isAdmin()             { return hasRole('admin'); }
    function isEditor()            { return hasAnyRole(['admin', 'editor']); }
    function isWriter()            { return hasAnyRole(['admin', 'editor', 'writer']); }
    function isNewsletterBuilder() { return hasAnyRole(['admin', 'newsletter_builder']); }
    function isMarketing()         { return hasAnyRole(['admin', 'marketing']); }
    // Marketing OS surfaces shared by both marketing and the social media
    // team: subscriber stats, subscriber list, social posts, searchability.
    function isMarketingOS()       { return hasAnyRole(['admin', 'marketing', 'social_media']); }
    function isStaff()             { return hasAnyRole(['admin', 'editor', 'writer', 'newsletter_builder', 'marketing', 'social_media']); }

    // Grant-aware capability helpers. An admin can hand the writing composer
    // or the editing queue to ANY role via Extra access (Users & roles), so
    // these wrap the base-role checks with the matching route grants. Keep
    // the hash lists in sync with GRANTABLE_ROUTES (js/dashboard/admin.js).
    function canWriteStories() {
      return isWriter()
        || hasAnyGrant(['#/writer/draft', '#/writer/mine', '#/book-reviews/write', '#/book-reviews/mine']);
    }
    function canEditStories() {
      return isEditor() || hasAnyGrant(['#/editor/queue', '#/admin/articles']);
    }

    // ---------- users ----------
    // Anonymous tokens are explicitly excluded — only real (email/password)
    // accounts can have a /users doc, which is what gates every staff role.
    match /users/{uid} {
      // Self, admins, and editors always. Other staff (writer / newsletter /
      // marketing) can read the directory too: the always-on pipeline panels
      // and the staff/editor pickers (loadUsers / loadEditors / loadStaff)
      // need to resolve teammate names and roles.
      allow read: if isRealUser() && (request.auth.uid == uid || isStaff());
      // Users can create their own doc on first login.
      // Only safe bootstrap roles allowed — no self-assigning admin/editor.
      allow create: if isRealUser()
        && request.auth.uid == uid
        && request.resource.data.role in ['reader', 'writer'];
      // Users can update safe fields on their own doc, but NOT privilege
      // fields. `role` and `extraAccess` are both admin-only — since the
      // security rules now honor extraAccess grants, letting a user write
      // their own extraAccess would be a self-escalation path.
      allow update: if isRealUser()
        && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'extraAccess']);
      // Admins can do anything to any user.
      allow read, write: if isAdmin();
    }

    // ---------- stories ----------
    match /stories/{storyId} {
      allow read: if resource.data.status == 'published';
      allow read: if isStaff();

      allow create: if canWriteStories()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status in ['draft', 'pending'];

      // Author can update their own draft.
      allow update: if canWriteStories()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.status in ['draft', 'pending'];

      // Final-review publish: once an admin has approved the piece, the author
      // can flip status from 'approved' to 'published' from the final-review
      // page. No other transitions out of 'approved' are permitted for writers.
      allow update: if canWriteStories()
        && resource.data.authorId == request.auth.uid
        && resource.data.status == 'approved'
        && request.resource.data.status == 'published';

      // Author can delete their own draft/pending piece (before it ships).
      allow delete: if canWriteStories()
        && resource.data.authorId == request.auth.uid
        && resource.data.status in ['draft', 'pending'];

      // Editors / admins (or users granted the editor queue / All articles
      // page) can update, assign, approve, publish. Deleting other people's
      // stories stays with real editors/admins.
      allow update: if canEditStories();
      allow delete: if isEditor();

      // Games grant: a non-editor explicitly granted the Games page may
      // attach/clear a story's brain-teaser game, but ONLY the `game` field —
      // they can't touch headline, body, status, or any other content. Keeps
      // the grant scoped to exactly what the Games dashboard writes.
      allow update: if hasGrant('#/admin/games')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['game']);

      // ----- nested collections on a story -----
      match /comments/{commentId} {
        allow read: if isStaff();
        allow create: if canEditStories()
          && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if canEditStories()
          && resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin();
      }

      match /checklist/{itemId} {
        allow read: if isStaff();
        allow write: if canEditStories();
      }

      // ----- editor suggestions (track-changes style) -----
      // Editors create suggestions on any draft.
      // The author of the parent story (and any editor) can read them.
      // The author can accept/reject (= delete). Editors can also delete their own.
      match /suggestions/{suggestionId} {
        allow read: if isStaff();
        allow create: if canEditStories()
          && request.resource.data.authorId == request.auth.uid;
        allow update: if canEditStories()
          && resource.data.authorId == request.auth.uid;
        allow delete: if canEditStories()
          || (canWriteStories() && get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid);
      }
    }

    // ---------- assignments (admin -> editor mapping) ----------
    match /assignments/{assignmentId} {
      allow read: if isStaff();
      allow write: if isEditor();
      allow delete: if isAdmin();
    }

    // ---------- subscribers ----------
    // Canonical write path is POST /api/subscribe (server-side, service account).
    // Anonymous create allowed as a fallback; reads are staff-only.
    match /subscribers/{emailKey} {
      allow read: if isMarketingOS() || isNewsletterBuilder() || isEditor()
        || hasAnyGrant(['#/marketing/subscribers', '#/marketing/analytics', '#/newsletter/builder']);
      allow create: if
        request.resource.data.email is string
        && request.resource.data.email.matches('.+@.+\\..+')
        && request.resource.data.status == 'active';
      allow update, delete: if isAdmin();
    }

    // ---------- newsletter campaigns ----------
    match /newsletter_campaigns/{campaignId} {
      allow read: if isNewsletterBuilder() || isMarketing()
        || hasAnyGrant(['#/newsletter/builder', '#/newsletter/history']);
      allow create, update: if (isNewsletterBuilder() || hasGrant('#/newsletter/builder'))
        && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ---------- catalyst bot reminder log ----------
    // Written exclusively by the server-side bot (service account bypasses
    // these rules). Admins may read it for debugging/audit.
    match /bot_reminder_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- collaboration requests (contact / collaborate form) ----------
    match /collaboration_requests/{reqId} {
      // Anyone (even anonymous) can submit the contact form.
      allow create: if
        request.resource.data.email is string
        && request.resource.data.email.matches('.+@.+\\..+');
      allow read: if isMarketing() || hasGrant('#/marketing/collabs');
      allow update, delete: if isAdmin();
    }

    // ---------- public book-review submissions ("The Catalyzers") ----------
    // Reader-submitted book reviews. The ONLY write path is the server-side
    // POST /api/book-reviews/submit endpoint (Cloudflare Pages Function,
    // service account, IP rate-limited, honeypot, header-injection
    // hardened, payload size capped). Direct client creates are denied so
    // attackers can't bypass the rate-limiter or the email-notification
    // pipeline by writing straight to Firestore. Reads are admin-only —
    // submissions contain submitter PII (email, IP, user-agent).
    match /bookReviewSubmissions/{subId} {
      allow create: if false;                  // server-only (service acct bypasses)
      // Admins always; a non-admin explicitly granted the Book reviews queue
      // route may read (but not mutate) the reader-submission queue.
      allow read: if isAdmin() || hasGrant('#/admin/book-reviews');
      allow update, delete: if isAdmin();
    }

    // ---------- analytics events (page views, signups, etc.) ----------
    match /analytics_events/{eventId} {
      allow create: if true; // anonymous logging permitted
      allow read: if isMarketingOS() || hasGrant('#/marketing/analytics');
      allow update, delete: if isAdmin();
    }

    // ---------- user presence / last-seen ----------
    match /user_presence/{uid} {
      // Real (non-anonymous) users update their own presence on login.
      allow read: if isEditor() || hasGrant('#/admin/activity');
      allow write: if isRealUser() && request.auth.uid == uid;
    }

    // ---------- admin task preferences (snooze / clear of dashboard tasks) ----------
    // Each admin owns a single doc keyed by their uid holding an `overrides`
    // map. Purely personal UI state — only the owning admin can read or write it.
    match /taskPrefs/{uid} {
      allow read, write: if isAdmin() && request.auth.uid == uid;
    }

    // ---------- workflow projects ----------
    // Author-match fallback: a project may have been seeded/migrated with an
    // authorId that no longer equals the user's current Firebase UID. Match by
    // authorName against the caller's user doc name/email as a backstop so the
    // true author isn't locked out of their own project.
    function isProjectAuthor() {
      return resource.data.authorId == request.auth.uid
        || (resource.data.authorName != null
            && myUserDoc().data.name != null
            && resource.data.authorName.lower() == myUserDoc().data.name.lower())
        || (resource.data.authorName != null
            && myUserDoc().data.email != null
            && resource.data.authorName.lower() == myUserDoc().data.email.lower());
    }
    match /projects/{projectId} {
      // The workflow board (Catalyst in the Capital / Op-Eds / My Assignments)
      // is shown to every staff role in the dashboard, so every staff member
      // may read projects. Write paths below stay author/editor/admin-gated.
      allow read: if isStaff();
      // Writers (incl. users granted the writing pages) can only create
      // proposals under their own uid.
      allow create: if canWriteStories()
        && request.resource.data.authorId == request.auth.uid;
      // Authors can update their own project.
      // Assigned editors (editorId matches) can update their assigned project.
      // Admins can update any project.
      allow update: if isAdmin()
        || isProjectAuthor()
        || resource.data.editorId == request.auth.uid;
      // Comment chat: any staff member (incl. social_media via the Planner)
      // may post to a project's activity feed — but ONLY the chat fields,
      // nothing structural. Lets the social team ask the author questions
      // without gaining edit rights over the project itself.
      allow update: if isStaff()
        && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['activity', 'lastActivity', 'updatedAt']);
      // Only admin or the original author can delete.
      allow delete: if isAdmin()
        || isProjectAuthor();
    }

    // ---------- workflow tasks ----------
    match /tasks/{taskId} {
      // Tasks panel is shown to every staff role; reads are staff-wide.
      // Create/update stay with editorial roles (writer+) so marketing can
      // view the board without authoring tasks; delete is editor/admin.
      allow read: if isStaff();
      allow create: if isWriter();
      allow update: if isWriter();
      allow delete: if isEditor();
    }

    // ---------- workflow settings (meetings, overrides) ----------
    match /settings/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ---------- editorial calendar tasks ----------
    // Personal & shared tasks shown on the Overview calendar. Any staff
    // member can create a task (stamped with their own uid). Participants
    // can update (mark done / reopen); only the creator or an admin can
    // delete or rewrite it. The bot reads these server-side (Admin REST)
    // to send reminder emails on the reminder day + day-of.
    match /calendar_tasks/{taskId} {
      allow read: if isStaff();
      allow create: if isStaff()
        && request.resource.data.createdById == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAdmin()
        || resource.data.createdById == request.auth.uid
        || request.auth.uid in resource.data.participantIds;
      allow delete: if isAdmin()
        || resource.data.createdById == request.auth.uid;
    }

    // ---------- social media posts ----------
    match /social_posts/{postId} {
      allow read: if isStaff();
      allow create: if isStaff()
        && request.resource.data.proposerId == request.auth.uid;
      allow update: if isEditor()
        || (isStaff() && resource.data.proposerId == request.auth.uid);
      allow delete: if isAdmin()
        || (isStaff() && resource.data.proposerId == request.auth.uid);
    }

    // ---------- social post assignments ----------
    // Created from the Planner: "make a post for this article, due by X."
    // Assigners are admins or users explicitly granted '#/planner/assign'
    // (Users & roles → Extra access). The assignee can update their own
    // assignment (mark done / reopen); assigners and admins manage them.
    match /social_assignments/{assignmentId} {
      allow read: if isStaff();
      // Leads (admin / '#/planner/assign' grant) can assign anyone; any
      // staff member can add a tracker row they own themselves.
      allow create: if request.resource.data.createdById == request.auth.uid
        && (isAdmin()
            || hasGrant('#/planner/assign')
            || (isStaff() && request.resource.data.assigneeId == request.auth.uid));
      allow update: if isAdmin()
        || hasGrant('#/planner/assign')
        || resource.data.assigneeId == request.auth.uid
        || ('assigneeIds' in resource.data
            && request.auth.uid in resource.data.assigneeIds)
        || resource.data.createdById == request.auth.uid;
      allow delete: if isAdmin()
        || hasGrant('#/planner/assign')
        || (isStaff() && resource.data.createdById == request.auth.uid);
    }

    // ---------- planner cleared list ----------
    // "We've posted for this article — take it off the Planner." One doc per
    // cleared story (doc id = story id). Clearing/restoring is for the social
    // leads: admins or users granted '#/planner/assign'. Everyone on staff
    // can read so the Planner hides cleared stories for the whole team.
    match /planner_cleared/{storyId} {
      allow read: if isStaff();
      allow create: if (isAdmin() || hasGrant('#/planner/assign'))
        && request.resource.data.clearedById == request.auth.uid;
      allow delete: if isAdmin() || hasGrant('#/planner/assign');
      allow update: if false;
    }

    // ---------- public site settings ----------
    // Small admin-managed config the public site reads (e.g. articlesHero —
    // the optional override image behind the Articles page hero). Publicly
    // readable so the static site can fetch it via the Firestore REST API;
    // only admins can change it.
    match /site_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ---------- staff announcements ----------
    // Admin-authored alert banners shown at the top of every staff member's
    // dashboard Overview ("meeting today — Zoom link", "fill out the
    // When2meet"). Managed from Admin → Advanced tools → Announcements;
    // optionally also emailed to all staff via /api/notify/announcement.
    match /announcements/{announcementId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // ---------- manual directory entries ----------
    // People admins added to the Directory tab who don't have a dashboard
    // account (advisors, interns, alumni). Staff can look them up; only
    // admins manage them. Never readable publicly — phone numbers and
    // emails in here are private contact info.
    match /directory_contacts/{contactId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // ---------- direct messages (Directory tab chat) ----------
    // One doc per pair of teammates (doc id = sorted uids joined with '__').
    // Only the two participants can read or append to their thread — private
    // even from admins. The participant pair is frozen after creation so a
    // thread can't be re-pointed at someone else's conversation.
    match /dm_threads/{threadId} {
      // A not-yet-created thread (resource == null) reads as empty — the
      // listener attaches before the first message is sent. Once the doc
      // exists, only its two participants can read it.
      allow read: if isStaff()
        && (resource == null
            || request.auth.uid in resource.data.participantIds);
      allow create: if isStaff()
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isStaff()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;
    }

    // ---------- winners' lounge chat ----------
    // Public chatroom for solvers of the brain teaser. Anonymous auth required.
    // Anyone signed in (anonymously or otherwise) can read + post.
    // The `likes` counter can be incremented by exactly +1 by anyone signed in,
    // gated server-side by a paired write to /chat-likes/{messageId}_{uid}.
    // Admins can edit any field (name, message, title, likes, timestamp) and
    // delete any message via the admin dashboard. No author-side editing/deleting.
    match /winners-chat/{messageId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 50
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 500
        && (!('title' in request.resource.data) || request.resource.data.title == null
            || (request.resource.data.title is string && request.resource.data.title.size() <= 30))
        && request.resource.data.likes == 0;

      // Like-only updates by any signed-in user: bump `likes` by exactly +1
      // and only when the paired chat-likes record is written in the same batch.
      // OR: admin can rewrite any field.
      allow update: if (
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        && request.resource.data.likes == resource.data.likes + 1
        && existsAfter(/databases/$(database)/documents/chat-likes/$(messageId + "_" + request.auth.uid))
      ) || isAdmin();

      // Only admins can delete messages.
      allow delete: if isAdmin();
    }

    // ---------- chat likes (per-user idempotency records) ----------
    // Doc id format: {messageId}_{uid}. Existence prevents double-liking.
    match /chat-likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.messageId is string
        && likeId == request.resource.data.messageId + "_" + request.auth.uid;
      // Like records are immutable — no updates, no user deletes.
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
