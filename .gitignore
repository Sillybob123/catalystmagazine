# Node.js
node_modules/
npm-debug.log
yarn-error.log
gitignore/
firebase-functions/node_modules/

# Environment variables
.env
.env.local
.env.*
.dev.vars
.dev.vars.*
!.dev.vars.example
**/.dev.vars
**/.env

# Firebase service account keys (any location, any naming)
*-firebase-adminsdk-*.json
**/firebase-adminsdk*.json
serviceAccount*.json
service-account*.json

# Secrets / credentials — catch-all safety net
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# Cloudflare + build artifacts
.wrangler/
**/.wrangler/
cloudflare-dist/
worker-configuration.d.ts

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
logs/
*.log

# Build files
dist/
build/

# Local tooling
.claude/

# Local-only backups (never deployed; git history is the real record)
*.backup

# Source media for the hero frame-extractor — large, used only as input to
# scripts/extract-hero-frames.js. The extracted WebP frames in
# public/assets/hero-frames/ ARE committed and shipped.
*.mov
*.mp4

# Local source PNGs for hero book covers — converted to /images/book-reviews/*.webp
# which is what actually ships. Keep the heavy originals out of the repo.
/book1.png
/book2.png
/book3.png

# Source images for social previews — optimized versions live in
# /images/social/ and are what actually ships.
/bookprevie.jpeg
